# ==================== Media Bot 配置文件 ====================
# 复制此文件为 .env 并填入真实配置
# 使用方法: cp .env.example .env


# ==================== 必需配置 ====================

# Telegram Bot Token（必需）
# 从 @BotFather 获取
BOT_TOKEN=your_bot_token_here

# HDHive 账号（必需）
HDHIVE_USER=your_username
HDHIVE_PASS=your_password

# HDHive token（HTTP接口模式必需，用于替代浏览器抓取）
# 可从浏览器 Cookie 中获取 token
HDHIVE_TOKEN=

# HDHive接口地址（一般无需修改）
HDHIVE_BASE_URL=https://hdhive.com

# Next-Action ID（网站改版后可能变化）
HDHIVE_ACTION_QUERY=406a30f8054110881289ca1c583d02a21a307e070a
HDHIVE_ACTION_FINAL=40d113051115da037257dc66c9c3d94f3d6848e150
# 登录接口 Action ID（网站更新后可能变化）
HDHIVE_ACTION_LOGIN=600e7119a4ae58824a919da1e275646d4245b1ffd9
# 登录接口超时（秒）与重试次数
HDHIVE_LOGIN_TIMEOUT=45
HDHIVE_LOGIN_RETRIES=2


# ==================== 可选配置 ====================

# HDHive 用户 ID（可选，用于查询积分）
# 可在 HDHive 个人主页 URL 中找到（形如 /user/xxxxx）
HDHIVE_USER_ID=

# TMDB API Key（可选但推荐，用于显示影视信息和海报）
# 从 https://www.themoviedb.org 获取
TMDB_API_KEY=

# 权限控制（可选）
# 0 = 不限制，任何人都可以使用
# 其他值 = 只允许该 Telegram User ID 使用（从 @userinfobot 获取）
ALLOWED_USER_ID=0

# 自动解锁积分阈值（可选）
# 0 = 禁用自动解锁（默认），所有解锁都需要用户确认
# >0 = 当用户积分高于此值时自动解锁，无需确认
# 例如: AUTO_UNLOCK_THRESHOLD=100 表示积分大于100时自动解锁
AUTO_UNLOCK_THRESHOLD=0

# 自动签到 cron（可选，留空=禁用）
# 5段表达式：分 时 日 月 周
# 示例：每天早上 8:30 -> 30 8 * * *
CHECKIN_CRON=

# 自动签到时区（可选，默认 Asia/Shanghai）
CHECKIN_TIMEZONE=Asia/Shanghai

# 自动签到接口 action id（网站更新后可能变化）
CHECKIN_ACTION_ID=4085c9b55e34af7a29e9564a955be3ec5c410c577f

# 自动签到模式（0=普通签到 false, 1=赌狗签到 true）
CHECKIN_GAMBLE=0

# 日志文件路径（可选）
# 新变量：MEDIA_BOT_LOG_PATH；旧变量 HDHIVE_LOG_PATH 仍兼容
MEDIA_BOT_LOG_PATH=media_bot.log


# ==================== Symedia 集成（可选）====================

# Symedia 服务地址（用于自动添加115链接到 Symedia）
# 示例：http://127.0.0.1:8095
SA_URL=

# 115 网盘保存目录 ID
# 从 Symedia 中获取目录 ID
SA_PARENT_ID=

# 自动添加到 Symedia 的倒计时（秒）
# 默认 60 秒
SA_AUTO_ADD_DELAY=60

# Symedia API token（默认 symedia）
SA_TOKEN=symedia

# 是否允许115链接推送到 Symedia（1=开启, 0=关闭）
SA_ENABLE_115_PUSH=1


# ==================== 已废弃配置 ====================

# 目标群组 ID（已废弃，保留兼容性）
TARGET_GROUP_ID=0
