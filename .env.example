# ==================== Media Bot 配置文件 ====================
# 复制此文件为 .env 并填入真实配置
# 使用方法: cp .env.example .env


# ==================== 必需配置 ====================

# Telegram Bot Token（必需）
# 从 @BotFather 获取
BOT_TOKEN=your_bot_token_here

# HDHive Open API Key（必需）
# 在 HDHive 后台创建并复制 API Key
HDHIVE_API_KEY=your_open_api_key_here

# HDHive 接口地址（一般无需修改）
HDHIVE_BASE_URL=https://hdhive.com

# HDHive Open API 地址（一般无需修改）
HDHIVE_OPEN_API_BASE_URL=https://hdhive.com/api/open


# ==================== 可选配置 ====================

# TMDB API Key（关键词搜索推荐必填，用于搜索、显示影视信息和海报）
# 从 https://www.themoviedb.org 获取
TMDB_API_KEY=

# 权限控制（可选）
# 0 = 不限制，任何人都可以使用
# 其他值 = 只允许该 Telegram User ID 使用（从 @userinfobot 获取）
ALLOWED_USER_ID=0

# 自动解锁积分阈值（可选）
# 0 = 禁用自动解锁（默认），所有解锁都需要用户确认
# >0 = 当用户积分高于此值时自动解锁，无需确认
# 例如: AUTO_UNLOCK_THRESHOLD=100 表示积分大于100时自动解锁
AUTO_UNLOCK_THRESHOLD=0

# HDHive 解锁接口限速（可选）
# 所有解锁请求统一进入队列排队处理，默认 1 秒最多 3 次
# 超过速率后会自动等待，并在 Telegram 提示与 Docker 日志中显示
HDHIVE_UNLOCK_RATE_LIMIT_PER_SECOND=3

# 是否解析收到的 HDHive 链接（可选）
# 1 = 开启（默认）：直接在聊天里丢 hdhive.com/resource/... 或 hdhive.com/tmdb/... 会自动解析
# 0 = 关闭：只有 /hdt /hdm /hdd 等命令才会处理 HDHive
HDHIVE_PARSE_INCOMING_LINKS=1

# 自动签到 cron（可选，留空=禁用）
# 5段表达式：分 时 日 月 周
# 示例：每天早上 8:30 -> 30 8 * * *
CHECKIN_CRON=

# 自动签到时区（可选，默认 Asia/Shanghai）
CHECKIN_TIMEZONE=Asia/Shanghai

# 自动签到模式（0=普通签到 false, 1=赌狗签到 true）
CHECKIN_GAMBLE=0

# 日志文件路径（可选）
# 新变量：MEDIA_BOT_LOG_PATH；旧变量 HDHIVE_LOG_PATH 仍兼容
MEDIA_BOT_LOG_PATH=media_bot.log

# 是否启用调试日志（true/false）
# false = 默认仅输出 INFO 及以上；true = 输出 DEBUG，便于排查 STRM/inotify/ffprobe 行为
MEDIA_BOT_DEBUG=false

# STRM Telegram 通知目标 Chat ID（可选）
# 支持用户、群组、频道 Chat ID；留空则不发送 STRM 归档通知
TGBOT_NOTIFY_CHAT_ID=


# ==================== STRM 监控（可选）====================

# 是否启用 STRM 监控（1=启用, 0=关闭）
# 启用后会在后台递归监听 STRM_WATCH_DIR 下的 .strm 文件
STRM_WATCH_ENABLED=0

# ffprobe 可执行文件路径
# Docker 默认会安装到 /usr/local/bin/ffprobe
STRM_FFPROBE_PATH=/usr/local/bin/ffprobe

# 监控根目录（递归）
# 建议形如：/data/strm/watch
STRM_WATCH_DIR=

# 成功目录（整文件夹移动到这里）
# 当某个一级目录满足完成条件后，会整体移动到这里
STRM_DONE_DIR=

# 失败目录（单文件移动到这里）
# 仅失败的 .strm 会移动到这里，并保留相对目录层级
STRM_FAILED_DIR=

# STRM 状态持久化目录（建议挂载持久卷）
# 用于保存每个一级目录的批次计划 manifest，支持容器重启后恢复批次状态
# Docker Compose 默认已挂载 ./data:/app/data，因此通常保持默认值即可
# 若你改了挂载路径，请确保该目录位于持久卷内，否则重建容器后计划状态会丢失
STRM_STATE_DIR=/app/data/strm_state

# 单个条目进入 processing 后的租约时间（秒）
# 某个 .strm 一旦开始处理，就会先在 manifest 中标记为 processing
# 如果进程崩溃、容器被重启、线程异常退出，条目可能卡在 processing
# 超过该时间后，下次扫描会把它自动回退到 pending 并重新提交，避免批次永久卡死
# 生产建议：批量导入场景保持 1800；若上游极慢、单条 ffprobe 可能长时间阻塞，可提高到 3600
STRM_PROCESSING_LEASE_SECONDS=1800

# 已完成/失败 manifest 的保留时间（小时）
# 当批次状态为 completed 或 failed:* 且超过该保留期后，旧 manifest 会自动清理
# 作用：避免 STRM_STATE_DIR 长期积累大量历史状态文件，同时保留一段时间用于排查问题
# 0 或负数 = 关闭自动清理（不建议）
# 默认 168 = 保留 7 天；如果你排障周期更长，可改为 720（30 天）
STRM_STATE_RETENTION_HOURS=168


# 处理线程数（单位：个）
# 生产建议：默认 3；NAS / 小机器不建议盲目调高，避免 ffprobe 并发过大
STRM_MAX_WORKERS=3


# 单次 ffprobe 超时秒数（单位：秒）
# 生产建议：默认 60；如果上游链接响应慢可调到 90
STRM_TIMEOUT_S=60

# ffprobe 最大重试次数（单位：次）
# 例如 2 表示最多尝试 3 次（首次 + 2 次重试）
STRM_MAX_RETRIES=2

# ffprobe 的 -rw_timeout 参数（单位：微秒）
# 生产建议：15000000 = 15 秒；网络源特别慢时可提高到 30000000
STRM_RW_TIMEOUT_US=15000000

# ffprobe 的 -probesize 参数（单位：ffmpeg 字节尺寸字符串，如 12M / 32M）
# 生产建议：默认 12M；复杂流媒体可尝试 16M / 32M，但会更慢
STRM_PROBESIZE=12M

# ffprobe 的 -analyzeduration 参数（单位：微秒）
# 生产建议：默认 3000000 = 3 秒；不建议过大，避免整体处理过慢
STRM_ANALYZEDURATION=3000000

# 同一路径的短期去重时间（单位：秒）
# 文件刚处理完后的这段时间内，重复事件会被忽略
STRM_RECENT_EVENT_TTL=10

# 一级目录空闲判定时间（单位：秒）
# 生产建议：批量导入场景改为 120，避免多季/多子目录分批写入时过早进入 finalize 判定
STRM_IDLE_SECONDS=120

# 一级目录最小存活时间（单位：秒）
# 生产建议：批量导入场景改为 300，给上游慢写/晚到季目录留足缓冲时间
STRM_MIN_FOLDER_AGE_SECONDS=300

# 是否只把 WATCH_DIR 的下一层目录作为批次单位（1=是, 0=否）
# 生产建议：保持 1；按一级目录做批次计划与归档更稳
STRM_ONLY_FIRST_LEVEL_DIR=1


# ==================== STRM 空目录清理（手动命令 /rm_strm）====================

# 是否启用 /rm_strm 手动清理命令（1=启用, 0=关闭）
# 关闭时 Telegram 中执行 /rm_strm 会直接提示未启用
STRM_PRUNE_ENABLED=0

# 要扫描的 STRM 根目录列表，使用 | 分隔
# 默认示例对应电影 / 电视剧 / 动漫三个 share 根目录
# 例如：/volume2/strm/share/电影|/volume2/strm/share/电视剧|/volume2/strm/share/动漫
STRM_PRUNE_ROOTS=/volume2/strm/share/电影|/volume2/strm/share/电视剧|/volume2/strm/share/动漫

# 是否允许删除每个根目录下的一级子目录（1=允许, 0=保护）
# 生产默认建议 0，避免误删媒体库一级分类目录
STRM_PRUNE_ALLOW_DELETE_FIRST_LEVEL=0

# 是否允许删除传入的根目录本身（1=允许, 0=不允许）
# 生产默认建议 0，通常只清理根目录下面的空子树
STRM_PRUNE_INCLUDE_ROOTS=0

# 删除后是否通知 Emby 局部刷新并补做所属媒体库递归刷新（1=开启, 0=关闭）
# 如果你的 STRM 目录已经挂载到 Emby，建议开启
STRM_PRUNE_NOTIFY_EMBY=1

# Emby 服务地址
# 若留空，则回退读取 EMBY_URL；再留空则默认 http://172.17.0.1:8096
STRM_PRUNE_EMBY_URL=http://172.17.0.1:8096

# Emby API Key
# 若留空，则回退读取 EMBY_API_KEY 或 EMBYAPIKEY
STRM_PRUNE_EMBY_API_KEY=

# Emby /Library/Media/Updated 的 UpdateType
# 删除目录场景通常保持 Deleted
STRM_PRUNE_EMBY_UPDATE_TYPE=Deleted

# Emby HTTP 超时时间（秒）
STRM_PRUNE_HTTP_TIMEOUT=15

# Emby HTTP 最大尝试次数（含首次请求）
STRM_PRUNE_HTTP_RETRIES=3

# Emby HTTP 指数退避基数
# 第 1/2/3 次失败后的等待分别约为 1s / 2s / 4s
STRM_PRUNE_HTTP_BACKOFF=2.0


# ==================== Symedia 集成（可选）====================

# Symedia 服务地址（用于自动添加115链接到 Symedia）
# 示例：http://127.0.0.1:8095
SA_URL=

# 115 网盘保存目录 ID
# 从 Symedia 中获取目录 ID
SA_PARENT_ID=

# 自动添加到 Symedia 的倒计时（秒）
# 默认 60 秒
SA_AUTO_ADD_DELAY=60

# Symedia API token（默认 symedia）
SA_TOKEN=symedia

# 是否允许115链接推送到 Symedia（1=开启, 0=关闭）
SA_ENABLE_115_PUSH=1


# ==================== 已废弃配置 ====================

# 目标群组 ID（已废弃，保留兼容性）
TARGET_GROUP_ID=0
